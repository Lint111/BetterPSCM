{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["vitest/globals"]
	},
	"include": ["**/*.ts", "../src/**/*.ts"],
	"exclude": ["node_modules"]
}
