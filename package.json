{
  "name": "plastic-scm-pro",
  "displayName": "Plastic SCM Pro",
  "description": "Feature-complete Plastic SCM integration for VS Code — staging, diffs, branches, code reviews, and AI agent support via MCP",
  "version": "0.1.0",
  "publisher": "betterscm",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/betterscm/plastic-scm-pro"
  },
  "homepage": "https://github.com/betterscm/plastic-scm-pro#readme",
  "bugs": {
    "url": "https://github.com/betterscm/plastic-scm-pro/issues"
  },
  "keywords": [
    "plastic scm",
    "unity version control",
    "scm",
    "version control",
    "source control",
    "mcp",
    "plastic",
    "unity"
  ],
  "preview": true,
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension executes Plastic SCM CLI commands and makes REST API calls."
    }
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.plastic/plastic.workspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "plasticScm.stage",
        "title": "Stage",
        "icon": "$(add)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.unstage",
        "title": "Unstage",
        "icon": "$(remove)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.stageAll",
        "title": "Stage All Changes",
        "icon": "$(add)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.unstageAll",
        "title": "Unstage All",
        "icon": "$(remove)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.checkin",
        "title": "Check In Staged",
        "icon": "$(check)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.checkinAll",
        "title": "Check In All",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.openChange",
        "title": "Open Changes",
        "icon": "$(git-compare)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.revertChange",
        "title": "Revert Change",
        "icon": "$(discard)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.switchBranch",
        "title": "Switch Branch...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.createBranch",
        "title": "Create Branch...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.deleteBranch",
        "title": "Delete Branch",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.mergeTo",
        "title": "Merge To...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.createCodeReview",
        "title": "Create Code Review...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.openCodeReview",
        "title": "Open Code Review",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.inspectReviewComments",
        "title": "Inspect Review Comments",
        "icon": "$(comment-discussion)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.nextReviewComment",
        "title": "Next Review Comment",
        "icon": "$(arrow-down)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.prevReviewComment",
        "title": "Previous Review Comment",
        "icon": "$(arrow-up)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.exportReviewAudit",
        "title": "Export Review Audit",
        "icon": "$(export)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.createLabel",
        "title": "Create Label...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.update",
        "title": "Update Workspace",
        "icon": "$(cloud-download)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.showFileHistory",
        "title": "Show File History",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.annotateFile",
        "title": "Annotate (Blame)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.login",
        "title": "Sign In...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.logout",
        "title": "Sign Out",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.showHistoryGraph",
        "title": "Show History Graph",
        "icon": "$(git-commit)",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.listLockRules",
        "title": "List Lock Rules",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.createLockRule",
        "title": "Create Lock Rule...",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.deleteLockRules",
        "title": "Delete All Lock Rules",
        "category": "Plastic SCM"
      },
      {
        "command": "plasticScm.releaseLocks",
        "title": "Release Locks...",
        "category": "Plastic SCM"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "plasticScm.checkin",
          "group": "navigation",
          "when": "scmProvider == plasticScm"
        },
        {
          "command": "plasticScm.refresh",
          "group": "navigation",
          "when": "scmProvider == plasticScm"
        },
        {
          "command": "plasticScm.update",
          "group": "navigation",
          "when": "scmProvider == plasticScm"
        },
        {
          "command": "plasticScm.stageAll",
          "group": "1_staging",
          "when": "scmProvider == plasticScm"
        },
        {
          "command": "plasticScm.unstageAll",
          "group": "1_staging",
          "when": "scmProvider == plasticScm"
        },
        {
          "command": "plasticScm.checkinAll",
          "group": "2_checkin",
          "when": "scmProvider == plasticScm"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "plasticScm.stageAll",
          "when": "scmProvider == plasticScm && scmResourceGroup == changes",
          "group": "inline"
        },
        {
          "command": "plasticScm.unstageAll",
          "when": "scmProvider == plasticScm && scmResourceGroup == staged",
          "group": "inline"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "plasticScm.stage",
          "when": "scmProvider == plasticScm && scmResourceGroup == changes",
          "group": "inline"
        },
        {
          "command": "plasticScm.unstage",
          "when": "scmProvider == plasticScm && scmResourceGroup == staged",
          "group": "inline"
        },
        {
          "command": "plasticScm.openFile",
          "when": "scmProvider == plasticScm",
          "group": "inline"
        },
        {
          "command": "plasticScm.openChange",
          "when": "scmProvider == plasticScm",
          "group": "navigation"
        },
        {
          "command": "plasticScm.revertChange",
          "when": "scmProvider == plasticScm",
          "group": "1_modification"
        },
        {
          "command": "plasticScm.showFileHistory",
          "when": "scmProvider == plasticScm",
          "group": "2_history"
        }
      ],
      "view/item/context": [
        {
          "command": "plasticScm.openCodeReview",
          "when": "view == plasticScm.codeReviewsView && viewItem == codeReview",
          "group": "navigation"
        },
        {
          "command": "plasticScm.inspectReviewComments",
          "when": "view == plasticScm.codeReviewsView && viewItem == codeReview",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "plasticScm.createCodeReview",
          "when": "view == plasticScm.codeReviewsView",
          "group": "navigation"
        },
        {
          "command": "plasticScm.nextReviewComment",
          "when": "view == plasticScm.reviewCommentsView",
          "group": "navigation"
        },
        {
          "command": "plasticScm.prevReviewComment",
          "when": "view == plasticScm.reviewCommentsView",
          "group": "navigation"
        },
        {
          "command": "plasticScm.exportReviewAudit",
          "when": "view == plasticScm.reviewCommentsView",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "plasticScm.openFile",
          "when": "isInDiffEditor && resourceScheme == file && plasticScm.isActive",
          "group": "navigation"
        },
        {
          "command": "plasticScm.showFileHistory",
          "when": "plasticScm.isActive",
          "group": "navigation"
        },
        {
          "command": "plasticScm.annotateFile",
          "when": "plasticScm.isActive",
          "group": "navigation"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "plasticScmMcp",
        "label": "Plastic SCM"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "plasticScm.historyGraphView",
          "type": "webview",
          "name": "Graph",
          "when": "plasticScm.isActive"
        },
        {
          "id": "plasticScm.codeReviewsView",
          "name": "Code Reviews",
          "when": "plasticScm.isActive"
        },
        {
          "id": "plasticScm.reviewCommentsView",
          "name": "Review Comments",
          "when": "plasticScm.isActive && plasticScm.reviewActive"
        }
      ]
    },
    "configuration": {
      "title": "Plastic SCM",
      "properties": {
        "plasticScm.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Plastic SCM server URL (e.g., https://cloud.plasticscm.com or http://localhost:7178)"
        },
        "plasticScm.organizationName": {
          "type": "string",
          "default": "",
          "description": "Organization name"
        },
        "plasticScm.repositoryName": {
          "type": "string",
          "default": "",
          "description": "Repository name"
        },
        "plasticScm.workspaceGuid": {
          "type": "string",
          "default": "",
          "description": "Workspace GUID (auto-detected if possible)"
        },
        "plasticScm.pollInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "Status polling interval in milliseconds"
        },
        "plasticScm.showPrivateFiles": {
          "type": "boolean",
          "default": true,
          "description": "Show private (unversioned) files in changes list"
        },
        "plasticScm.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable MCP server for AI agent integration"
        }
      }
    }
  },
  "scripts": {
    "codegen": "openapi-typescript openapi/api-1.json -o src/api/generated/schema.d.ts",
    "build": "npm run codegen && node esbuild.config.mjs",
    "build:ext": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "openapi-fetch": "^0.13.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.27.4",
    "@esbuild/win32-x64": "^0.27.4",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.9",
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.9",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "electron": "^41.0.0",
    "esbuild": "^0.27.4",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
